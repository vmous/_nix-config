##############
# Networking #
##############

# List applications that are "listening" for incoming network connections
alias j-network-ls-listeners='sudo lsof -PiTCP -sTCP:LISTEN'
# Watch applications that are using a TCP or UDP connection
alias j-network-watch-tcp-udp='watch -n 1 "lsof -Pan -i tcp -i udp"'
# Restart DNS service
function j-network-dns-restart() {
  if [[ "${OSTYPE}" == "darwin"* ]]; then
    sudo dscacheutil -flushcache
    echo "macOS: Directory cache flashed."

    pgrep -f mDNSResponder | while read -r PID PNAME; do
      if [[ "${PID}" =~ ^[0-9]+$ ]]; then
        echo "Restarting mDNSResponder process: ${PNAME} (${PID})"
        sudo kill -9 "${PID}"
      fi
    done
  elif [[ "${OSTYPE}" == "linux-gnu"* ]]; then
    if systemctl is-active --quiet systemd-resolved; then
      # Use `systemd-resolved` (Modern)
      if command -v resolvectl > /dev/null; then
        sudo resolvectl flush-caches && sudo systemctl restart systemd-resolved
      else
        sudo systemd-resolve --flush-caches && sudo systemctl restart systemd-resolved
      fi
      echo "Linux: systemd-resolved flushed and restarted."
    elif systemctl is-active --quiet nscd; then
      # Use `nscd` (Common Legacy)
      sudo nscd -i hosts && sudo systemctl restart nscd
      echo "Linux: nscd flushed and restarted."
    elif systemctl is-active --quiet dnsmasq; then
      # Use `dnsmasq` (Lightweight/Router-style)
      sudo systemctl restart dnsmasq
      echo "Linux: dnsmasq restarted."
    elif systemctl is-active --quiet named; then
      # Check for BIND (Server-grade)
      sudo rndc flush && sudo systemctl restart named
      echo "Linux: BIND flushed and restarted."
    else
      # Final attempt: Restarting the network manager often triggers a refresh
      echo "No specific DNS daemon active. Attempting NetworkManager restart..."
      sudo systemctl restart NetworkManager || echo "Error: No recognized DNS manager found."
    fi
  else
    echo "Do not know how to restart DNS on unknown OS: ${OSTYPE}"
    return 1
  fi
}

############
# Datetime #
############

function j-datetime_now_to_timestamp() {
  echo $(date +%Y%m%d%H%M%S)
}

function j-datetime-epoch_to_date {
  if [ $# -ne 1 ]; then
    echo "Please provide the epoch date time."
    echo "Example: $0 <epoch>"
    return 1
  fi

  if [[ "${JMACHINE}" == "mac" ]]; then
    echo "$(date -r ${1})"
  else
    echo "$(date -d @${1})"
  fi
}

##############
# Filesystem #
##############

function j-fs-del-line-in-file {
  if [ $# -ne 2 ]; then
    echo "Please provide the line an the file you wish to delete."
    echo "Example: $0 <line> <file>"
    return 1
  fi

  local _line=$1
  local _file=$2
  if ! is_unsigned_integer "${_line}"; then
    echo "ERROR: <line> (first argument) must be a positive integer."
    return 1
  fi

  if ! is_text_file "${_file}"; then
    echo "ERROR: <file> (second argument) must be an existing, text file."
    return 1
  fi

  echo "${_file}:${_line}: " $(sed -n "${_line}"p "${_file}")

  if [[ $(yes_or_no "Do you want to delete the above line?") == "y" ]]; then
      $(backup_file "${_file}")
      if [[ ${JMACHINE} == "mac" ]]; then
        $(sed -i "" ${_line}'d' ${_file})
      else
        $(sed -i ${_line}'d' ${_file})
      fi
  fi
}

############################
# Remote System Management #
############################

function j-tmux() {
  cmd_exists tmux || { echo >&2 "Cannot find tmux. Aborting."; return; }

  local _legal=true
  if [[ ${#} -eq 0 ]]; then
    tmux ls
  elif [[ ${#} -eq 1 ]]; then
    tmux attach -t "${1}"
  elif [[ ${1} = "n" ]] && [[ ! -z "${2}" ]]; then
    tmux new -s "$2"
  elif [[ ${1} = "a" ]] && [[ ! -z "${2}" ]]; then
    tmux attach -t "$2"
  elif [[ ${1} = "r" ]] && [[ ! -z "${2}" ]]; then
    # Attach to a tmux session and make sure you refresh ssh-agent forwarding
    # on each window.
    # Note: this part requires all windows are "waiting" on shell prompt. If a
    # window is running a programm the keys below will be received by the
    # program.
    local _session="${2}"
    for _window in $(tmux list-windows -t "${2}" -F '#I'); do
      # clear prompt before
      tmux send-keys -t ${_session}:${_window} "C-c"
      tmux send-keys -t ${_session}:${_window} "export $(tmux show-environment | grep "^SSH_AUTH_SOCK")" ENTER
    done
    tmux attach -t "${2}"
  else
    _legal=false
  fi

  if [ "${_legal}" = false ]; then
    echo "Illegal use of ${0}. Try:"
    echo "Example: ${0} [n|a|r|] <session_name>"
  fi
}

function j-tmux-re() {
  # Nice snippet for reattaching tmux to ssh-agent
  # http://justinchouinard.com/blog/2010/04/10/fix-stale-ssh-environment-variables-in-gnu-screen-and-tmux/
  if [[ -n $TMUX ]]; then
    NEW_SSH_AUTH_SOCK=`=tmux showenv|grep '^SSH_AUTH_SOCK'|cut -d = -f 2`
    if [[ -n $NEW_SSH_AUTH_SOCK ]] && [[ -S $NEW_SSH_AUTH_SOCK ]]; then
      export SSH_AUTH_SOCK=$NEW_SSH_AUTH_SOCK
    fi
  fi
}

