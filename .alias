function j-which() {
  if command -v "${1}" >/dev/null 2>&1 ; then
    readlink -f `which "${1}"`
  else
    echo "Command ${1} does not exist."
  fi
}

##############################
# Jazzmanian _nix Life Hacks #
##############################

# Java
alias j-java-print-version='printf "\n☕️ Java\n\n" && which java && java -version'
alias j-java-switch-version='sudo alternatives --config java && source ~/.zshrc'

# Fonts

# Download a .zip from a URL and install the font faces it contains (TrueType
# .ttf or OpenType .otf) under ~/.local/share/fonts, replacing any previously
# installed copies. Everything is staged in a scratch dir and only swapped into
# place once the download + extract fully succeed, so a failure never leaves the
# machine without the font. The trap removes the scratch dir on every exit path
# (return, error, or Ctrl-C) so nothing goes stale. Callers are expected to
# refresh the font cache (fc-cache) once after all installs.
#
# This is the shared core behind `_j-install-font-from-github-release`
# (release archives) and `_j-install-font-from-github-tree` (repository
# source archives); those resolve the right URL and delegate here.
#   $1 label          - human-readable font name, used in messages
#   $2 url            - .zip URL to download
#   $3 archive_glob   - glob of the font files to extract from the archive
#   $4 installed_glob - glob of already-installed faces to replace
function _j-install-font-from-zip() {
  local _fn="${0}"  # this function's name, for user-facing messages
  local _label="$1" _url="$2" _archive_glob="$3" _installed_glob="$4"
  local _fonts_dir="${HOME}/.local/share/fonts"

  local _tmp_dir="$(mktemp -d)"
  trap "rm -rf -- '${_tmp_dir}'" EXIT
  local _zip="${_tmp_dir}/font.zip"
  local _stage="${_tmp_dir}/stage"

  # Plain -O (no --show-progress; unsupported on GNU Wget < 1.16).
  run wget -O "${_zip}" "${_url}" \
    || { echo_error "${_fn}: download of ${_label} failed. Aborting."; return 1; }
  # Extract the wanted faces into the staging area first.
  run mkdir -p "${_stage}"
  run unzip -j "${_zip}" "${_archive_glob}" -d "${_stage}" \
    || { echo_error "${_fn}: extraction of ${_label} failed. Aborting."; return 1; }
  # Guard against an upstream layout change silently installing nothing.
  # (N) is a zsh null-glob qualifier: the pattern expands to nothing when
  # there is no match instead of erroring under the default NOMATCH option.
  local _staged=( "${_stage}"/*.(ttf|otf)(N) )
  if (( ${#_staged} == 0 )); then
    echo_error "${_fn}: no ${_label} font files found in the archive. Aborting."
    return 1
  fi

  # Only now that we have good fonts do we replace the installed set.
  run mkdir -p "${_fonts_dir}"
  # Drop any previously installed faces of this font so we start clean.
  # (${~var} forces the glob stored in the variable to be expanded.)
  run rm -f "${_fonts_dir}"/${~_installed_glob}(N)
  run mv "${_staged[@]}" "${_fonts_dir}"/
}

# Install a font published as a GitHub *release* asset. Resolves the versioned
# .zip URL from the latest release, then delegates to
# `_j-install-font-from-zip`.
#   $1 label          - human-readable font name, used in messages
#   $2 repo           - GitHub "owner/name" whose latest release is fetched
#   $3 asset_match    - substring identifying the .zip asset in the release.
#                       It is matched at a word boundary: the substring must be
#                       followed by a non-letter (a version separator) or the
#                       ".zip" suffix, so e.g. "Iosevka" will not match
#                       "IosevkaTerm.zip". This makes selection independent of
#                       the order assets happen to appear in the API response.
#   $4 archive_glob   - glob of the font files to extract from the archive
#   $5 installed_glob - glob of already-installed faces to replace
function _j-install-font-from-github-release() {
  local _fn="${0}"  # this function's name, for user-facing messages
  local _label="$1" _repo="$2" _asset_match="$3" _archive_glob="$4" _installed_glob="$5"
  local _api="https://api.github.com/repos/${_repo}/releases/latest"

  echo "Installing ${_label}..."

  # Release assets are version-stamped (e.g. CascadiaCode-2407.24.zip), so
  # there is no stable .../latest/download/<name> URL to hit directly. Ask the
  # GitHub API for the latest release and pull the matching .zip URL out of it.
  # The "([^A-Za-z]...)?\.zip" tail anchors the match to a word boundary so a
  # prefix like "Iosevka" does not also match "IosevkaTerm.zip".
  local _url="$(wget -qO- "${_api}" \
    | grep -oE "https://[^\"]*${_asset_match}([^A-Za-z][^\"]*)?\.zip" | head -1)"
  if [[ -z "${_url}" ]]; then
    echo_error "${_fn}: could not resolve the ${_label} download URL. Aborting."
    return 1
  fi

  _j-install-font-from-zip "${_label}" "${_url}" "${_archive_glob}" "${_installed_glob}"
}

# Install a font that lives in a GitHub repository *tree* rather than a release
# (some projects, e.g. Crimson Pro, ship no release archives). Downloads the
# repository source archive for a branch via the codeload endpoint, then
# delegates to `_j-install-font-from-zip`. Because the whole repo is fetched the
# `archive_glob` must include the archive's top-level "<repo>-<branch>/" prefix
# -- a leading "*/" handles that.
#   $1 label          - human-readable font name, used in messages
#   $2 repo           - GitHub "owner/name" to fetch
#   $3 branch         - branch to download (e.g. main, master)
#   $4 archive_glob   - glob of the font files to extract from the archive
#   $5 installed_glob - glob of already-installed faces to replace
function _j-install-font-from-github-tree() {
  local _label="$1" _repo="$2" _branch="$3" _archive_glob="$4" _installed_glob="$5"
  local _url="https://github.com/${_repo}/archive/refs/heads/${_branch}.zip"

  echo "Installing ${_label}..."

  _j-install-font-from-zip "${_label}" "${_url}" "${_archive_glob}" "${_installed_glob}"
}

# Install font files that already exist somewhere on this machine by copying
# them into a destination font directory. Unlike the download helpers above
# this downloads nothing: its primary use case is for proprietary fonts that
# ship bundled inside a licenced application already installed on your machine
# (e.g. Adobe's `Minion Pro` / `Myriad Pro` whose OTFs come inside an Adobe
# Acrobat installation). The faces are copied. Missing sources are a clean
# no-op, not an error, so it is safe to call on a machine that lacks the
# bundling app.
#   $1  label    - human-readable font name, used in messages
#   $2  dest_dir - directory to copy the faces into
#   $3  src_glob - glob (may contain spaces/**) matching source directories
#   $4+ patterns - one or more filename globs of the faces to copy
function _j-install-font-from-local() {
  local _fn="${0}"  # this function's name, for user-facing messages
  local _label="$1" _dest_dir="$2" _src_glob="$3"
  shift 3
  local _patterns=( "$@" )

  echo "Installing ${_label}..."

  # Collect the source directories, then the matching faces within them.
  # (${~var} forces the glob stored in the variable to be expanded; (N/)
  # keeps only existing directories and yields nothing when none match.)
  local _src_dirs=( ${~_src_glob}(N/) )
  local _found=() _dir _pat
  for _dir in "${_src_dirs[@]}"; do
    for _pat in "${_patterns[@]}"; do
      _found+=( "${_dir}"/${~_pat}(N) )
    done
  done

  if (( ${#_found} == 0 )); then
    echo_warning "${_fn}: no source font files found for ${_label} (is the bundling app installed?). Skipping."
    return 0
  fi

  run mkdir -p "${_dest_dir}"
  # -f overwrites stale copies so re-runs stay idempotent.
  run cp -f "${_found[@]}" "${_dest_dir}/"
  echo "${_label}: installed ${#_found} face(s) into ${_dest_dir}"
}

# Install fonts across machines
#
# Cascadia
# - Website: https://learn.microsoft.com/en-us/windows/terminal/cascadia-code
# - Github: https://github.com/microsoft/cascadia-code
# - Homebrew: https://formulae.brew.sh/cask/font-cascadia-code
# - Notes: open source; source-code monospace;
#
# Crimson Pro
# - Website: https://fonts.google.com/specimen/Crimson+Pro
# - Github: https://github.com/Fonthausen/CrimsonPro
# - Homebrew: https://formulae.brew.sh/cask/font-crimson-pro
# - Notes: open source; prose/body serif;
#
# Fira Code
# - Website: -
# - Github: https://github.com/tonsky/FiraCode
# - Homebrew: https://formulae.brew.sh/cask/font-fira-code
# - Notes: open source; source-code monospace;
#
# Iosevka (base + Nerd Font) and Iosevka Term Nerd Font
# - Website: https://typeof.net/Iosevka/
# - Github:
#   - https://github.com/be5invis/Iosevka (upstream)
#   - https://github.com/ryanoasis/nerd-fonts (for nerd font)
# - Homebrew: https://formulae.brew.sh/cask/font-iosevka
# - Notes: open source; source-code monospace;
#
# JetBrains Mono
# - Website: https://www.jetbrains.com/lp/mono/
# - Github: https://github.com/JetBrains/JetBrainsMono
# - Homebrew: https://formulae.brew.sh/cask/font-jetbrains-mono
# - Notes: open source; source-code monospace;
#
# Minion Pro
# - Website: https://fonts.adobe.com/fonts/minion
# - Notes: closed source/proprietary; prose/body serif; ships together with
#          licensed Adobe Acrobat / Reader installations
#
# Monaspace
# - Website: https://monaspace.githubnext.com/
# - Github: https://github.com/githubnext/monaspace
# - Homebrew: https://formulae.brew.sh/cask/font-monaspace
# - Notes: open source; source-code monospace;
#
# Myriad Pro
# - Website: https://fonts.adobe.com/fonts/myriad
# - Notes: closed source/proprietary; prose/body serif; ships together with
#          licensed Adobe Acrobat / Reader installations
#
# Source Code Pro
# - Website: https://fonts.adobe.com/fonts/source-code-pro
# - Github: https://github.com/adobe-fonts/source-code-pro
# - Homebrew: https://formulae.brew.sh/cask/font-source-code-pro
# - Notes: open source; source-code monospace;
#
# Source Serif 4
# - Website: https://fonts.adobe.com/fonts/source-serif
# - Github: https://github.com/adobe-fonts/source-serif
# - Homebrew: https://formulae.brew.sh/cask/font-source-serif-4
# - Notes: open source; prose/body serif;
function j-install-fonts() {
  local _fn="${0}"  # this function's name, for user-facing messages

  if [[ "${JMACHINE}" == "mac" ]]; then
    cmd_exists brew || { echo_error "${_fn}: cannot find brew. Aborting."; return 1; }
    run brew install --cask \
      font-cascadia-code font-cascadia-code-nf \
      font-crimson-pro \
      font-fira-code font-fira-code-nerd-font \
      font-iosevka font-iosevka-nerd-font font-iosevka-term-nerd-font \
      font-jetbrains-mono font-jetbrains-mono-nerd-font \
      font-monaspace font-monaspace-nf \
      font-source-code-pro font-sauce-code-pro-nerd-font \
      font-source-serif-4

    ########## Install proprietary fonts ##########
    # Install fonts that are not freely downloadable by copying the OTFs
    # that ship inside licenced software already available on your systems.

    _j-install-font-from-local "Minion Pro" "${HOME}/Library/Fonts" \
      "/Applications/Adobe Acrobat*/**/Resource/Font" \
      "Minion*.otf"

    _j-install-font-from-local "Myriad Pro" "${HOME}/Library/Fonts" \
      "/Applications/Adobe Acrobat*/**/Resource/Font" \
      "MyriadPro-*.otf"
  else
    for _cmd in wget unzip fc-cache; do
      cmd_exists "${_cmd}" || { echo_error "${_fn}: cannot find ${_cmd}. Aborting."; return 1; }
    done

    _j-install-font-from-github-release "Cascadia Code" "microsoft/cascadia-code" \
      "CascadiaCode" "ttf/static/*.ttf" "*Cascadia*.ttf" || return 1

    # Ships no release archives, so it is fetched from the repository tree
    # (`master` branch). The static TTFs live under `fonts/ttf/` inside the
    # archive's top-level dir.
    _j-install-font-from-github-tree "Crimson Pro" "Fonthausen/CrimsonPro" \
      "master" "*/fonts/ttf/*.ttf" "*CrimsonPro*.ttf" || return 1

    _j-install-font-from-github-release "Fira Code" "tonsky/FiraCode" \
      "Fira_Code" "ttf/*.ttf" "*FiraCode*.ttf" || return 1

    # Iosevka
    # Shipped from official upstream (be5invis/Iosevka)
    # The release ships many packs; "PkgTTF-Iosevka" selects the base family;
    # faces sit at the archive root, hence the flat "*.ttf" glob; the
    # "Iosevka-*.ttf" cleanup glob is scoped so it does not remove sibling
    # Iosevka variants installed below.
    _j-install-font-from-github-release "Iosevka" "be5invis/Iosevka" \
      "PkgTTF-Iosevka" "*.ttf" "Iosevka-*.ttf" || return 1

    # Iosevka NF
    # Patched faces pulled from ryanoasis/nerd-fonts (as official upstream
    # ships no Nerd Font build).
    # The Iosevka.zip / IosevkaTerm.zip assets hold the NerdFont / NerdFontMono
    # / NerdFontPropo faces at the archive root; the word-boundary asset match
    # keeps "Iosevka" from selecting "IosevkaTerm"; the cleanup globs are
    # scoped to each family so they do not clobber base Iosevka above or each
    # other.
    _j-install-font-from-github-release "Iosevka Nerd Font" "ryanoasis/nerd-fonts" \
      "Iosevka" "*.ttf" "IosevkaNerdFont*.ttf" || return 1
    _j-install-font-from-github-release "Iosevka Term Nerd Font" "ryanoasis/nerd-fonts" \
      "IosevkaTerm" "*.ttf" "IosevkaTermNerdFont*.ttf" || return 1

    _j-install-font-from-github-release "JetBrains Mono" "JetBrains/JetBrainsMono" \
      "JetBrainsMono" "fonts/ttf/*.ttf" "*JetBrainsMono*.ttf" || return 1

    # Ships OpenType (`.otf`) faces in per-family subdirectories, so its archive
    # glob differs from TrueType fonts.
    _j-install-font-from-github-release "Monaspace" "githubnext/monaspace" \
      "monaspace-static" "*.otf" "*Monaspace*.otf" || return 1

    _j-install-font-from-github-release "Source Code Pro" "adobe-fonts/source-code-pro" \
      "TTF-source-code-pro" "TTF/*.ttf" "*SourceCodePro*.ttf" || return 1

    # The desktop archive nests the static faces under a versioned top dir,
    # hence the `"*/TTF/*.ttf"` glob.
    _j-install-font-from-github-release "Source Serif 4" "adobe-fonts/source-serif" \
      "Desktop" "*/TTF/*.ttf" "*SourceSerif4*.ttf" || return 1

    # Refresh the font cache once, after all fonts are installed.
    run fc-cache -fv
  fi
}

# Spell-checking

# Install hunspell and download dictionaries to expected directory
function j-install-spell-checking() {
  local _fn="${0}"  # this function's name, for user-facing messages

  # Languages to install dictionaries for. Each entry is either:
  #   - a bare prefix (e.g. "en", "es") -- installs every variant the language
  #     ships (en_US, en_GB, ...; all 20+ Spanish locales, ...), or
  #   - a full locale (e.g. "es_ES")    -- installs only that one dictionary.
  # The upstream directory is always resolved from the base prefix (so both
  # "es" and "es_ES" look in the "es" directory, and "el"/"el_GR" in "el_GR").
  local _langs=(el en_GB en_US es_ES)

  if [[ "${JMACHINE}" != "mac" ]]; then
    echo_warning "${_fn}: automatic installation is not supported yet on '${JMACHINE}'. Skipping."
    return 0
  fi

  # Install hunspell only when it is not already
  if ! cmd_exists hunspell; then
    cmd_exists brew || { echo_error "${_fn}: cannot find brew. Aborting."; return 1; }
    run brew install hunspell \
      || { echo_error "${_fn}: hunspell install failed. Aborting."; return 1; }
  fi

  cmd_exists curl || { echo_error "${_fn}: cannot find curl. Aborting."; return 1; }

  # Ensure the user dictionary directory exists (already searched by
  #    hunspell by default on macOS).
  local _dict_dir="${HOME}/Library/Spelling"
  [[ -d "${_dict_dir}" ]] || run mkdir -p "${_dict_dir}"

  # Download the dictionaries for the configured languages from the LibreOffice
  # dictionaries repo. The repo groups variants of a language under a single
  # directory (e.g. `en' holds en_US/en_GB/...; `es' holds every es_XX locale),
  # while some languages live under a locale-named directory (e.g. `el_GR');
  # the loop therefore resolves the directory from each entry's base prefix.
  local _base="https://cgit.freedesktop.org/libreoffice/dictionaries"
  local _lang _base_lang _name_pat _dir _file _count=0
  for _lang in "${_langs[@]}"; do
    echo "Fetching '${_lang}' dictionaries..."
    # The base prefix (text before the first `_'/`-') selects the upstream
    # directory; a full locale (e.g. `es_ES') narrows the downloaded files to
    # that exact stem, while a bare prefix (e.g. `es') matches every stem.
    _base_lang="${_lang%%[_-]*}"
    if [[ "${_lang}" == "${_base_lang}" ]]; then
      _name_pat='[^'\''"/]+'   # any filename stem
    else
      _name_pat="${_lang}"     # only this exact locale
    fi
    # Discover the top-level language directories (exactly `xx' or starting
    # `xx_'/`xx-') by scraping the cgit tree root, so both `el' and `el_GR'
    # style names are handled.
    local _dirs=( $(curl -fsSL "${_base}/tree/" \
      | grep -oiE "/tree/${_base_lang}([_-][a-z0-9]+)?" \
      | sed 's#.*/##' | sort -u) )
    if (( ${#_dirs} == 0 )); then
      echo_warning "${_fn}: no '${_lang}' language directory found upstream. Skipping."
      continue
    fi
    for _dir in "${_dirs[@]}"; do
      # Pull the matching .aff/.dic filenames out of the directory's cgit tree
      # listing (`_name_pat' is a single stem for a full locale, or any stem
      # for a bare prefix). `hyph_*' files are hyphenation patterns, not
      # spelling dictionaries, so they are filtered out.
      local _files=( $(curl -fsSL "${_base}/tree/${_dir}" \
        | grep -oE "/tree/${_dir}/${_name_pat}\.(aff|dic)" \
        | sed 's#.*/##' | grep -v '^hyph_' | sort -u) )
      if (( ${#_files} == 0 )); then
        echo_warning "${_fn}: no .aff/.dic files found in '${_dir}'. Skipping."
        continue
      fi
      for _file in "${_files[@]}"; do
        # cgit serves raw blobs under the 'plain' endpoint.
        if run curl -fsSL -o "${_dict_dir}/${_file}" \
             "${_base}/plain/${_dir}/${_file}"; then
          (( _count++ ))
        else
          echo_warning "${_fn}: failed to download '${_dir}/${_file}'."
        fi
      done
    done
  done

  echo "${_fn}: installed ${_count} dictionary file(s) into ${_dict_dir}"
}


# Crazy
function terminal-benchmark() {
  # https://en.wikipedia.org/wiki/ANSI_escape_code
  # https://unix.stackexchange.com/questions/17680/italics-in-emacs-on-a-text-terminal-rxvt-unicode
  # https://unix.stackexchange.com/questions/269077/tput-setaf-color-table-how-to-determine-color-codes

  # TBD some colors are equal? 5==12 6==13
  # TBD color 0 == bg fix it
  echo "# General"
  echo "TERM=${TERM}"
  echo
  echo "# Terminal colors"
  echo Colors available: $(tput colors)
  echo "foregrounds:" $(printf '\e[%sm▒' {30..37} 0)
  echo "backgrounds:" $(printf '\e[%sm ' {40..47} 0)
  #echo
  #printf '\e[48;5;%dm ' {0..255}; printf '\e[0m \n'
  #echo
  color() {
    for c; do
      printf ' \e[48;5;%dm%03d\e[0m' $c $c
    done
    printf '\n'
  }

  IFS=$' \t\n'
  color {0..15}
  for ((i=0;i<6;i++)); do
    color $(seq $((i*36+16)) $((i*36+51)))
  done
  color {232..255}
  #for i in {0..255} ; do printf "\x1b[38;5;${i}mcolour${i}\n"; done

  # fg 42 over bg 17
  # printf '\033[38;5;%dm\033[48;5;%dm%s\033[0m\n' 42 17 "Hello, world."

  # 24bit support?
  # for ((r=0;r<255;r++)); do
  #   for ((g=0;g<255;g++)); do
  #     for ((b=0;b<255;b++)); do
  #       printf '\e[48;2;%d;%d;%dma' $r $g $b
  #     done
  #   done
  # done
  echo
  echo "# Fonts"
  echo Styles: '\e[3mitalic\e[0m' '\e[1mbold\e[0m' '\e[4munderline\e[0m' '\e[1m\e[3mbolditalics\e[0m'
  printf "More examples: \e[5mblink\e[0m \e[5m\e[1;38;2;255;0;0mFATAL\e[0m\n"
  echo Does not work in URxvt/tmux: "\e[9mstrikethrough\e[0m" "\e[2mfaint\e[0m"
  echo URxvt matcher links: http://www.megalogy.org tramp://.
  STR=pa
  echo "normal  0-7 " $(printf "\e[38;5;%sm$STR\e[0m" {0..7})
  echo "bold    0-7 " $(printf "\e[1;38;5;%sm$STR\e[0m" {0..7})
  echo "normal 8-15 " $(printf "\e[38;5;%sm$STR\e[0m" {8..15})
  echo "bold   8-15 " $(printf "\e[1;38;5;%sm$STR\e[0m" {8..15})
  echo
  echo "# Other terminal features"
  echo "## WM Urgent on BEL (ascii 0x7)"
  printf "\007"

  echo "## UTF-8 support"
  echo "Greek: αάΑΆβΒγΓδΔεέΕΈζΖηήΗΉθΘιίϊΐΙΊκΚλΛμΜνΝξΞοόΟΌπΠρΡσΣτΤυύϋΰΥΎφΦχΧψΨωώΩω"
  echo "Greek (polytonic): ἊῳᾧὸόῩ"
  echo "Arabic: ﷽"
  echo "Spanish: ñ áéíóú"
  echo "Katakana: イロハニホヘト"
  echo "Hebrew: מצא"
  echo "Russian: В чащах юга жил бы цитрус? Да, но фальшивый экземпляр!"
  echo "German: Heizölrückstoßabdämpfung"
  echo "Emoji: 📅"
  echo "Symbols: ∅∇∀∃"

  echo "## TBD SIXEL support"
  #cat ~/share/t/console/sfa3.sixel

  echo "## OSC 52: Clipboard setting"
  # Ms in terminfo

  ORIG="This is a clipoard test"
  BASE64=$(echo $ORIG |base64)
  printf "\e]52;;$BASE64\007"
  CLP=$(xsel -p -o)

  if [[ "$ORIG" = "$CLP" ]]; then
    echo "OSC 52 supported :)"
  else
    echo "OSC 52 not supported :("
  fi

  echo "## OSC 4: Set colors"
  printf "\e]4;00;rgb:3f/3f/3f\007"
  printf "\e]4;01;rgb:70/50/50\007"
  printf "\e]4;02;rgb:60/b4/8a\007"
  printf "\e]4;03;rgb:df/af/8f\007"
  printf "\e]4;04;rgb:50/60/70\007"
  printf "\e]4;05;rgb:dc/8c/c3\007"
  printf "\e]4;06;rgb:8c/d0/d3\007"
  printf "\e]4;07;rgb:dc/dc/cc\007"

  printf "\e]4;08;rgb:70/90/80\007"
  printf "\e]4;09;rgb:cc/93/93\007"
  printf "\e]4;10;rgb:7f/9f/7f\007"
  printf "\e]4;11;rgb:f0/df/af\007"
  printf "\e]4;12;rgb:94/bf/f3\007"
  printf "\e]4;13;rgb:ec/93/d3\007"
  printf "\e]4;14;rgb:93/e0/e3\007"
  printf "\e]4;15;rgb:ff/ff/ff\007"

  echo "## Hyperlinks"
  URL=http://jazzman.webhop.net
  printf "   \e]8;;$URL\007$URL\e]8;;\007\n"
  URL=file://localhost/
  echo "   \e]8;;$URL\007$URL\e]8;;\007"
}
