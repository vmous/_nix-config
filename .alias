################################################################################
alias l='less'
# https://stackoverflow.com/questions/77223684
function lesslogFunc {
  local pattern=${1:?}/**/${2:?}(om[1])
  less +G -- ${~pattern}
}
alias less-log='noglob lesslogFunc'

